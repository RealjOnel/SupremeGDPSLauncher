<Window x:Class="SupremeGDPSLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Supreme GDPS Launcher"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1F1F1F">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0D0D0D">
            <StackPanel Margin="20">
                <TextBlock Text="Supreme GDPS"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,20,0,5"/>
                <TextBlock Text="Launcher"
                           Foreground="#AAAAAA"
                           FontSize="16"
                           Margin="0,0,0,40"/>

                <Button Content="Home" Height="40" Margin="0,0,0,10" Click="HomeButton_Click"/>
                <Button Content="Updates" Height="40" Margin="0,0,0,10" Click="UpdatesButton_Click"/>
                <Button Content="Features" Height="40" Margin="0,0,0,10" Click="FeaturesButton_Click"/>
                <Button Content="Settings" Height="40" Margin="0,0,0,10" Click="SettingsButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Background="#242424">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="587*"/>
                <ColumnDefinition Width="93*"/>
            </Grid.ColumnDefinitions>
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Margin="145,0,0,0">
                <TextBlock x:Name="MainTitle"
                           Text="Welcome to Supreme GDPS"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Button Content="Launch Supreme GDPS"
                        Width="260"
                        Height="50"
                        Margin="0,0,0,15"
                        Click="LaunchButton_Click"/>

                <Button Content="Open Game Directory"
                        Width="260"
                        Height="40"
                        Margin="0,0,0,10"
                        Click="OpenGameDirectory_Click"/>

                <Button Content="Open AppData Folder"
                        Width="260"
                        Height="40"
                        Click="OpenAppDataFolder_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>